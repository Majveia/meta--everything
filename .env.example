# YouTube Data API v3 key (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=

# Twitch API credentials (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=
TWITCH_ACCESS_TOKEN=
TWITCH_USERNAME=

# X / Twitter API bearer token (https://developer.x.com/en/portal/dashboard)
X_API_BEARER_TOKEN=
# Comma-separated X usernames to fetch tweets from
X_ACCOUNTS=

# Comma-separated Substack publication slugs (e.g. "platformer,stratechery")
SUBSTACK_PUBLICATIONS=

# Comma-separated Kick channel slugs
KICK_CHANNELS=

# Public URL for OpenGraph metadata
NEXT_PUBLIC_URL=https://metaeverything.app
