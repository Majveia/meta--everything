# meta//everything — environment template
# Copy to .env.local and fill in the values you want to use.
# Any section can be omitted; missing platforms fall back to mock content.

# ───────── Site ─────────
# Base URL used for metadata / OG tags
NEXT_PUBLIC_URL=https://metaeverything.app

# ───────── YouTube ─────────
# https://console.cloud.google.com/ → enable "YouTube Data API v3" → create API key
YOUTUBE_API_KEY=

# ───────── Twitch ─────────
# https://dev.twitch.tv/console/apps → register app → get Client ID
# Access token: https://twitchtokengenerator.com (scope: user:read:follows)
TWITCH_CLIENT_ID=
TWITCH_ACCESS_TOKEN=
# Optional — Twitch username to pull "following" streams for (defaults to majveia)
TWITCH_USERNAME=

# ───────── X (Twitter) ─────────
# https://developer.x.com → project → bearer token
X_API_BEARER_TOKEN=
# Comma-separated X handles to include in the feed (no @)
X_ACCOUNTS=

# ───────── Substack ─────────
# Comma-separated Substack publication slugs (from publication URL: <slug>.substack.com)
SUBSTACK_PUBLICATIONS=

# ───────── Kick ─────────
# Comma-separated Kick channel slugs
KICK_CHANNELS=
